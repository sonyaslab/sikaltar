# ============================================================
# SIKALTARA — Konfigurasi Lingkungan
# Salin file ini menjadi .env dan sesuaikan nilainya
# ============================================================

# --- Database PostgreSQL ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://sikaltara:sikaltara2024@localhost:5432/sikaltara_db

# --- Redis (untuk Celery task queue) ---
REDIS_URL=redis://localhost:6379/0

# --- Aplikasi ---
APP_ENV=development          # development | production
LOG_LEVEL=INFO

# --- Autentikasi JWT ---
JWT_SECRET_KEY=GANTI_DENGAN_KUNCI_RAHASIA_MINIMAL_32_KARAKTER_ACAK!
JWT_EXPIRE_HOURS=8           # Durasi token (jam)

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- PDRB Config ---
TAHUN_DASAR=2010             # Tahun dasar harga konstan
PROVINSI_KODE=65             # Kode BPS Kalimantan Utara
