# ============================================================
# SIKALTARA — Konfigurasi Lingkungan
# Salin file ini menjadi .env dan sesuaikan nilainya
# ============================================================

# --- Database PostgreSQL ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=sqlite:///./test_sikaltara.db

# Jika menggunakan PostgreSQL lokal (tanpa Docker), ubah ke:
# DATABASE_URL=sqlite:///./test_sikaltara.db

# --- Redis (untuk Celery task queue) ---
REDIS_URL=redis://localhost:6379/0

# --- Aplikasi ---
APP_ENV=development          # development | production
APP_SECRET_KEY=ganti-dengan-kunci-rahasia-anda-minimal-32-karakter
LOG_LEVEL=INFO

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- PDRB Config ---
TAHUN_DASAR=2010             # Tahun dasar harga konstan
PROVINSI_KODE=65             # Kode BPS Kalimantan Utara
