# ====== SALIN ke .env, ISI nilai asli, JANGAN commit ke git ======

# Domain publik (untuk HTTPS otomatis Caddy). Contoh: sikaltara.kaltaraprov.go.id
DOMAIN=contoh-domain-anda.go.id

# Database PostgreSQL
POSTGRES_USER=sikaltara
POSTGRES_PASSWORD=GANTI_password_kuat_acak_panjang
POSTGRES_DB=sikaltara_db

# Kunci rahasia JWT — WAJIB diganti dengan string acak panjang
# Buat dengan:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=GANTI_dengan_string_acak_panjang
JWT_EXPIRE_HOURS=8
